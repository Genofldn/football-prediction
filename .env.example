# Football Prediction Pipeline — API Keys (copy to .env and fill in)
# Source before running any script:  source .env

export FOOTBALL_API_KEY=your_api_football_key      # https://www.api-football.com/
export ODDS_API_KEY=your_odds_api_key              # https://the-odds-api.com/
export NEWS_API_KEY=your_newsapi_key               # https://newsapi.org/

# API-Football Pro plan flag: "1" = 1s delay (100 req/min), "0" = 7s (free tier)
export FOOTBALL_PRO_PLAN=0
